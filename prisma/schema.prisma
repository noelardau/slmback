generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model collectif {
  idCollectif    Int       @id @default(autoincrement())
  nomCollectif   String
  ville          String
  email          String    @unique
  password       String
  photoCollectif String?
  membres        membre[]
  tournois       tournoi[]
}

model membre {
  idMembre       Int      @id @default(autoincrement())
  nomMembre      String
  prenomMembre   String
  photoMembre    String?
  dateNaissance  DateTime
  adresse        String
  idCollectif    Int
  collectif      collectif @relation(fields: [idCollectif], references: [idCollectif], onDelete: Cascade)
}

model tournoi {
  idTournoi      Int       @id @default(autoincrement())
  LieuTournoi    String
  dateTournoi    DateTime
  heureTournoi   String
  nomTournoi     String
  nbJury         Int
  afficheTournoi String?
  idCollectif    Int
  collectif      collectif @relation(fields: [idCollectif], references: [idCollectif], onDelete: Cascade)
}