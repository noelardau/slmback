generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model collectif {
  idCollectif    Int      @id @default(autoincrement())
  nomCollectif   String
  ville          String
  email          String   @unique
  password       String
  photoCollectif String?
  membres        membre[]
}

model membre {
  idMembre       Int      @id @default(autoincrement())
  nomMembre      String
  prenomMembre   String
  photoMembre    String?
  dateNaissance  DateTime
  adresse        String
  idCollectif    Int
  collectif      collectif @relation(fields: [idCollectif], references: [idCollectif], onDelete: Cascade)
}