generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model collectif {
  idCollectif    Int     @id @default(autoincrement())
  nomCollectif   String
  ville          String
  email          String  @unique
  password       String
  photoCollectif String?
}